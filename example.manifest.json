{
  "manifest_version": 3,
  "name": "Gerador de Forms via JSON",
  "version": "1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "identity"
  ],
  "host_permissions": [
    "https://forms.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "SEU_CLIENT_ID_REAL.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/forms.body"
    ]
  }
}